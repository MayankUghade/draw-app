generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id          Int      @id @default(autoincrement())
  email       String   @unique
  name        String 
  password    String
  rooms       Room[]
  chats       Chat[]
}

model Room{
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  adminId     Int
  admin       User     @relation(fields: [adminId], references: [id])
  chats       Chat[]
}

model Chat{
  id          Int      @id @default(autoincrement())
  message     String
  roomId      Int
  room        Room     @relation(fields: [roomId], references: [id])
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}