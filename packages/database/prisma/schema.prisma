generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String
  name     String
  photo    String?
  room     Room[]
  chat     Chat[]
}

model Room {
  id        Int     @id @default(autoincrement())
  name      String
  slug      String
  authorId  Int
  admin     User @relation(fields: [authorId], references: [id]) 
  chat      Chat[]
}

model Chat{
  id        Int     @id @default(autoincrement())
  roomId    Int
  message   String
  userId    Int
  user      User @relation(fields: [userId], references: [id])
  room      Room @relation(fields: [roomId], references: [id])
}
